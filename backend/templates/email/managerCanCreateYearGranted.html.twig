{% apply inline_css %}
<style>
    body { margin: 0; padding: 0; background-color: #f0edf5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; }
    .wrapper { width: 100%; background-color: #f0edf5; padding: 40px 0; }
    .card { max-width: 560px; margin: 0 auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(100,0,130,0.10); }
    .header { background-color: #7b1fa2; padding: 36px 40px; text-align: center; }
    .header-logo { font-size: 32px; font-weight: 800; color: #ffffff; letter-spacing: 3px; margin: 0; }
    .header-tagline { font-size: 12px; color: #e1bee7; letter-spacing: 2px; margin: 8px 0 0; text-transform: uppercase; }
    .body { padding: 48px 48px 36px; text-align: center; }
    .icon { font-size: 48px; margin: 0 0 20px; }
    .title { font-size: 22px; font-weight: 700; color: #2d1b3d; margin: 0 0 16px; }
    .text { font-size: 15px; color: #5c5c7a; line-height: 1.7; margin: 0 0 28px; }
    .badge { display: inline-block; background-color: #f3e5f5; color: #7b1fa2; font-weight: 700; font-size: 15px; padding: 8px 20px; border-radius: 20px; margin: 0 0 28px; }
    .granted-box { background: #f3e5f5; border-left: 4px solid #9c27b0; border-radius: 8px; padding: 16px 20px; margin: 0 0 28px; text-align: left; font-size: 14px; color: #4a1260; line-height: 1.6; }
    .btn-wrap { text-align: center; margin: 0 0 20px; }
    .btn { display: inline-block; background-color: #9c27b0; color: #ffffff !important; font-size: 15px; font-weight: 700; text-decoration: none; padding: 14px 44px; border-radius: 50px; }
    .divider { border: none; border-top: 1px solid #ede7f6; margin: 28px 0; }
    .note { font-size: 13px; color: #9e9eb8; line-height: 1.6; margin: 0 0 8px; }
    .footer { background-color: #f8f5fb; padding: 24px 40px; text-align: center; border-top: 1px solid #ede7f6; }
    .footer-text { font-size: 12px; color: #b0a8c0; margin: 0; line-height: 1.6; }
    .footer-brand { color: #9c27b0; font-weight: 700; text-decoration: none; }
</style>

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Nouveau droit accordé — MED@WORK</title>
</head>
<body>
<div class="wrapper">
    <table width="100%" cellpadding="0" cellspacing="0">
        <tr>
            <td align="center" style="padding: 0 16px;">
                <table class="card" width="560" cellpadding="0" cellspacing="0">
                    <tr>
                        <td class="header">
                            <p class="header-logo">MED@WORK</p>
                            <p class="header-tagline">Gestion des résidents médicaux</p>
                        </td>
                    </tr>
                    <tr>
                        <td class="body">
                            <p class="icon">🔑</p>
                            <h1 class="title">Nouveau droit accordé, {{ firstname }} !</h1>
                            <p class="badge">{{ hospitalName }}</p>
                            <p class="text">
                                Un nouveau droit vous a été accordé sur la plateforme MED@WORK.
                            </p>
                            <div class="granted-box">
                                <strong>Droit accordé :</strong> Création d'années académiques<br>
                                <strong>Accordé par :</strong> {{ grantedByName }}<br>
                                <strong>Le :</strong> {{ grantedAt }}
                            </div>
                            <p class="text" style="margin-bottom: 28px;">
                                Vous pouvez désormais créer de nouvelles années académiques
                                pour l'hôpital <strong>{{ hospitalName }}</strong>.
                            </p>
                            <div class="btn-wrap">
                                <a href="{{ loginUrl }}" class="btn">Accéder à MED@WORK</a>
                            </div>
                            <hr class="divider">
                            <p class="note">Si vous pensez avoir reçu cet email par erreur, contactez votre administrateur.</p>
                        </td>
                    </tr>
                    <tr>
                        <td class="footer">
                            <p class="footer-text">
                                © {{ "now"|date("Y") }} <a href="#" class="footer-brand">MED@WORK</a> — Tous droits réservés<br>
                                Cet email a été envoyé automatiquement, merci de ne pas y répondre.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</div>
</body>
</html>
{% endapply %}
