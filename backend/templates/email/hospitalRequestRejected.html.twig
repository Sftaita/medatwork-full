{% apply inline_css %}
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <style type="text/css">
    body, p, div { font-family: 'Viga', Arial, sans-serif; font-size: 14px; }
    body { color: #000000; background-color: #ffffff; margin: 0; padding: 0; }
    a { color: #a439b6; text-decoration: none; }
    .wrapper { width: 100%; max-width: 600px; margin: 0 auto; }
    .header { background-color: #a439b6; padding: 30px; text-align: center; }
    .header h1 { color: #ffffff; font-size: 28px; margin: 0; }
    .body { padding: 40px 50px; background-color: #ffffff; }
    .footer { background-color: #a439b6; padding: 30px; text-align: center; color: #ffffff; font-size: 14px; }
    .footer a { color: #ffffff; text-decoration: underline; }
  </style>
</head>
<body>
  <table class="wrapper" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td class="header">
        <h1>Votre demande n'a pu être retenue</h1>
      </td>
    </tr>
    <tr>
      <td class="body">
        <p style="font-size:16px; margin-bottom:16px;">Bonjour <strong>{{ firstname }}</strong>,</p>
        <p style="margin-bottom:16px;">
          Nous vous informons que votre demande de rattachement à <strong>{{ hospitalName }}</strong>
          n'a pas pu être retenue par notre équipe.
        </p>
        <p style="margin-bottom:16px;">
          Si vous pensez qu'il s'agit d'une erreur ou si vous souhaitez soumettre une nouvelle demande,
          vous pouvez nous contacter directement.
        </p>
        <p style="color:#888; font-size:12px; margin-top:24px;">
          Si vous n'êtes pas à l'origine de cette demande, ignorez cet email.
        </p>
      </td>
    </tr>
    <tr>
      <td class="footer">
        <p>Des questions ? <a href="{{ frontend_url }}/contactUs">Contactez-nous</a></p>
      </td>
    </tr>
  </table>
</body>
</html>
{% endapply %}
