{% apply inline_css %}
<html xmlns="http://www.w3.org/1999/xhtml">
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1">
    <style type="text/css">
      body, p, div { font-family: 'Viga', sans-serif; font-size: 14px; }
      body { color: #000000; background-color: #ffffff; }
      body a { color: #000000; text-decoration: none; }
      p { margin: 0; padding: 0; }
    </style>
    <link href="https://fonts.googleapis.com/css?family=Viga&display=swap" rel="stylesheet">
  </head>
  <body>
    <center style="width:100%; background-color:#ffffff;">
      <table width="600" align="center" cellpadding="0" cellspacing="0" border="0" style="max-width:600px;">
        <tr>
          <td style="padding:40px 0 20px 0; text-align:center;">
            <img src="http://cdn.mcauto-images-production.sendgrid.net/4cac3d0403b3ec90/8bfcc76b-0f52-48bf-8a75-0c926fe5c3f8/144x144.png" width="80" height="80" alt="MED@WORK">
          </td>
        </tr>
        <tr>
          <td style="padding:20px 30px; text-align:center; background-color:#ffffff;">
            <p style="font-size:32px; color:#a63ab8; line-height:1.3;">
              Félicitations !
            </p>
          </td>
        </tr>
        <tr>
          <td style="padding:20px 0 10px; text-align:center;">
            <span style="font-size:80px; line-height:1;">🏆</span>
          </td>
        </tr>
        <tr>
          <td style="padding:10px 50px 40px; text-align:center; font-size:16px; color:#554c56; line-height:1.6;">
            <p>Vous avez été désigné(e) administrateur de l'hôpital <strong>{{ hospitalName }}</strong> sur la plateforme MED@WORK.</p>
            <br>
            <p>Votre accès administrateur sera bientôt configuré. Vous recevrez les informations de connexion prochainement.</p>
          </td>
        </tr>
        <tr>
          <td style="padding:40px; text-align:center; background-color:#a439b6;">
            <p style="color:#ffffff; font-size:16px;">
              Des questions ? <a href="https://www.medatwork.be/contactUs" style="color:#ffffff;"><u>Contactez-nous</u></a>
            </p>
          </td>
        </tr>
      </table>
    </center>
  </body>
</html>
{% endapply %}
