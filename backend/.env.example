# ============================================================
# .env.example — Medatwork Backend
# ============================================================
# Copiez ce fichier en .env.local et renseignez les valeurs.
# Ne committez JAMAIS .env.local ni les vraies credentials.
#
#   cp .env.example .env.local
#
# ============================================================

###> symfony/framework-bundle ###
APP_ENV=dev
# APP_ENV=prod
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format : mysql://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL="mysql://root:@127.0.0.1:3306/medcligmedatwork"
###< doctrine/doctrine-bundle ###

###> nelmio/cors-bundle ###
# Dev : autoriser localhost
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
# Prod : décommenter et adapter
# CORS_ALLOW_ORIGIN="https://www.medatwork.be"
###< nelmio/cors-bundle ###

###> URLs ###
# URL de base de l'API (utilisée dans les emails)
API_URL="http://localhost:8000/api/"
# URL du frontend (liens reset password, activation)
FRONTEND_URL="http://localhost:3000"
###< URLs ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem

# ⚠️  OBLIGATOIRE : générer une passphrase forte (≥ 32 caractères aléatoires)
#    openssl rand -base64 48
JWT_PASSPHRASE=CHANGE_ME_openssl_rand_base64_48
###< lexik/jwt-authentication-bundle ###

###> mailer — Hostinger SMTP ###
# En prod : smtps://USER%40DOMAIN:PASSWORD@smtp.hostinger.com:465
# En dev  : utiliser Mailpit (voir docker-compose.yml)
#   MAILER_DSN=smtp://localhost:1025
MAILER_DSN=smtps://no-reply%40medatwork.be:HOSTINGER_PASSWORD@smtp.hostinger.com:465
###< mailer — Hostinger SMTP ###

###> sentry/sentry-symfony ###
# Laisser vide pour désactiver Sentry
# DSN disponible dans : Sentry → Project Settings → Client Keys
SENTRY_DSN=
APP_VERSION=1.0.0
###< sentry/sentry-symfony ###

###> symfony/lock ###
LOCK_DSN=flock
###< symfony/lock ###
