# Force LF line endings for all text files
* text=auto eol=lf

# Windows batch files need CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pem binary
*.p12 binary
*.pfx binary
*.ttf binary
*.woff binary
*.woff2 binary
*.eot binary
*.otf binary
*.xlsx binary
*.xls binary
*.pdf binary
