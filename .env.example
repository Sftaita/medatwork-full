# Docker Compose — local secrets
# Copy this file to .env and fill in real values.
# .env is git-ignored and must NEVER be committed.

# MySQL
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_PASSWORD=change_me_app

# Symfony
APP_SECRET=change_me_32_chars_random_string_here
JWT_PASSPHRASE=change_me_32_chars_random_string_here

# External services (leave empty to disable in dev)
SENDGRID_API_KEY=
SENTRY_DSN=
